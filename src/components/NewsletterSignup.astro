---
// Inline Beehiiv subscribe form. The loader script appends the form into
// the container element. The framed heading + subhead stay legible even
// before the script loads, so the section never collapses to empty.
//
// Headline uses Inter (--font-sans) for hierarchy against article body
// text; the subhead uses Source Serif 4 (--font-serif) so it reads in
// continuity with the long-form prose above it. Light/dark mode is
// inherited via the existing --foreground / --muted-foreground tokens.
---

<section
  aria-labelledby="newsletter-signup-heading"
  class="border-border bg-muted/30 my-12 rounded-md border border-dashed px-5 py-8 text-center sm:px-8 sm:py-10"
>
  <h2
    id="newsletter-signup-heading"
    class="text-foreground font-sans text-2xl font-semibold tracking-tight sm:text-3xl"
    style="font-family: var(--font-sans);"
  >
    Get new posts by email
  </h2>
  <p
    class="text-muted-foreground mx-auto mt-3 max-w-prose text-base sm:text-lg"
    style="font-family: var(--font-serif);"
  >
    Notes on requirements, problem-framing, and the BA craft. No spam,
    unsubscribe anytime.
  </p>
  <div class="mt-6 flex justify-center">
    <script
      is:inline
      async
      src="https://subscribe-forms.beehiiv.com/v3/loader.js"
      data-beehiiv-form="99df1d7d-e98a-4de3-a4c6-1272408e66c8"></script>
  </div>
</section>
