---
// Inline Beehiiv subscribe form.
//
// We embed the form as a direct <iframe> rather than via Beehiiv's
// loader.js script. The script-loader path was flaky on iOS Safari:
// it occasionally failed to inject the form into the article-page
// instance (heading + description visible, form missing), and the
// injected iframe sometimes rendered wider than its container in
// dark mode, breaking out of the dashed-border section. A direct
// iframe avoids both: no UA-sniffing in the loader, no async
// injection timing, full CSS control over the iframe element.
//
// Headline uses Inter (--font-sans) for hierarchy against article
// body text; the subhead uses Source Serif 4 (--font-serif) so it
// reads in continuity with the long-form prose above it. Light/dark
// mode is inherited via the existing --foreground / --muted-foreground
// tokens.
//
// The iframe src is the same URL the Beehiiv loader navigates to;
// `?slim=true` keeps the framed form to just input+button, no
// branding header.
const FORM_ID = "99df1d7d-e98a-4de3-a4c6-1272408e66c8";
const formSrc = `https://subscribe-forms.beehiiv.com/v3/forms/${FORM_ID}?slim=true`;
---

<section
  aria-labelledby="newsletter-signup-heading"
  class="newsletter-signup border-border bg-muted/30 my-12 overflow-hidden rounded-md border border-dashed px-5 py-8 text-center sm:px-8 sm:py-10"
>
  <h2
    id="newsletter-signup-heading"
    class="text-foreground font-sans text-2xl font-semibold tracking-tight sm:text-3xl"
    style="font-family: var(--font-sans);"
  >
    Get new posts by email
  </h2>
  <p
    class="text-muted-foreground mx-auto mt-3 max-w-prose text-base sm:text-lg"
    style="font-family: var(--font-serif);"
  >
    Notes on requirements, problem-framing, and the BA craft. No spam,
    unsubscribe anytime.
  </p>
  <div class="mt-6 w-full">
    <iframe
      src={formSrc}
      title="Subscribe to RequirementsFirst"
      class="newsletter-signup__iframe block w-full max-w-full"
      style="border: 0; min-height: 150px; max-width: 100%;"
      loading="lazy"
      scrolling="no"
    ></iframe>
  </div>
</section>

<style>
  /*
   * Defensive width clamp — Beehiiv's iframe content occasionally
   * sets an internal min-width on iOS Safari that pushes the frame
   * past its container. Force the element-level width regardless of
   * any inline width attribute Beehiiv adds.
   */
  .newsletter-signup,
  .newsletter-signup * {
    box-sizing: border-box;
  }
  .newsletter-signup__iframe {
    width: 100% !important;
    max-width: 100% !important;
    display: block;
  }
</style>
